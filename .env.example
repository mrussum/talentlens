# Required — Anthropic API key. NEVER commit a real value to git.
# This is read server-side only; the frontend bundle never sees it.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Claude tuning
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2400
CLAUDE_TEMPERATURE=0.3

# Comma-separated origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Where the browser bundle should send /api/* calls in the docker-compose build.
# Override this if you front the app with a reverse proxy.
VITE_API_BASE=http://localhost:8000/api
